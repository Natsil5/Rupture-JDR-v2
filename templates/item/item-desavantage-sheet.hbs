<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" height="64" width="64"/>
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{item.name}}" placeholder="Nom du désavantage"/></h1>
    </div>
  </header>
  <section class="sheet-body">
    <div class="form-group">
      <label>Effet</label>
      <textarea name="system.effet" rows="8">{{system.effet}}</textarea>
    </div>
    <div class="form-group">
      <label>Gain (points)</label>
      <input type="number" name="system.gain" value="{{system.gain}}" data-dtype="Number"/>
    </div>
  </section>
</form>
