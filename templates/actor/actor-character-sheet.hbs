<form class="{{cssClass}} flexcol" autocomplete="off">

  {{!-- Feuille Header --}}
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
    
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Nom du Personnage"/>
      </h1>
      
      <div class="identity-grid">
        <div class="identity-field">
          <label>Espèce</label>
          <select name="system.race">
            <option value="" {{#unless system.race}}selected{{/unless}}>— Choisir une espèce —</option>
            <option value="humain" {{#if (eq system.race "humain")}}selected{{/if}}>Humain</option>
            <option value="fae" {{#if (eq system.race "fae")}}selected{{/if}}>Faë</option>
            <option value="jorogumo" {{#if (eq system.race "jorogumo")}}selected{{/if}}>Jorogumo</option>
            <option value="pantherine" {{#if (eq system.race "pantherine")}}selected{{/if}}>Panthérine</option>
            <option value="warabouc" {{#if (eq system.race "warabouc")}}selected{{/if}}>Warabouc</option>
            <option value="wendigo" {{#if (eq system.race "wendigo")}}selected{{/if}}>Wendigo</option>
            <option value="worg" {{#if (eq system.race "worg")}}selected{{/if}}>Worg</option>
          </select>
        </div>

        <div class="identity-field">
          <label>Sexe</label>
          <input type="text" name="system.sexe" value="{{system.sexe}}" placeholder="Sexe"/>
        </div>

        <div class="identity-field">
          <label>Âge</label>
          <input type="text" name="system.age" value="{{system.age}}" placeholder="Âge"/>
        </div>

        <div class="identity-field">
          <label>Archétype</label>
          <input type="text" name="system.archetype" value="{{system.archetype}}" placeholder="Archétype"/>
        </div>

        <div class="identity-field experience">
          <label>Expérience</label>
          <div class="exp-values">
            <input type="text" name="system.experience.value" value="{{system.experience.value}}" data-dtype="Number"/>
            <span> / </span>
            <input type="text" name="system.experience.total" value="{{system.experience.total}}" data-dtype="Number"/>
          </div>
        </div>
      </div>

      {{!-- Avantages et Désavantages --}}
      <div class="advantages-section">
        <div class="advantages-list">
          <label>Avantages:</label>
          <div class="tags">
            {{#each avantages as |item|}}
              <span class="tag advantage">{{item.name}}</span>
            {{else}}
              <span class="tag-empty">Aucun</span>
            {{/each}}
          </div>
        </div>
        <div class="disadvantages-list">
          <label>Désavantages:</label>
          <div class="tags">
            {{#each desavantages as |item|}}
              <span class="tag disadvantage">{{item.name}}</span>
            {{else}}
              <span class="tag-empty">Aucun</span>
            {{/each}}
          </div>
        </div>
      </div>

      {{!-- Ressources --}}
      <div class="resources-section">
        <div class="resource-line">
          <div class="resource-main">
            <label>Santé</label>
            <div class="resource-value">
              <input type="text" name="system.sante.value" value="{{system.sante.value}}" data-dtype="Number"/>
              <span> / {{system.sante.max}}</span>
              <span class="mult">(×{{system.sante.multiplicateur}})</span>
            </div>
          </div>

          <div class="resource-multiplier">
            <label>Mult. PV</label>
            <input type="number" name="system.sante.multiplicateur" value="{{system.sante.multiplicateur}}" data-dtype="Number" min="0" max="10"/>
          </div>

          <div class="resource-main">
            <label>Barrière</label>
            <div class="resource-value">
              <input type="text" name="system.barriere.value" value="{{system.barriere.value}}" data-dtype="Number"/>
              <span> / </span>
              <input type="text" name="system.barriere.max" value="{{system.barriere.max}}" data-dtype="Number" style="width: 50px;"/>
            </div>
          </div>
        </div>

        <div class="resource-line">
          <div class="resource-nexus">
            <label>Nexus</label>
            <div class="nexus-circles-container">
              {{nexusCircles system.nexus.value system.nexus.max}}
              <span class="nexus-text">{{system.nexus.value}}/{{system.nexus.max}}</span>
            </div>
          </div>

          <div class="resource-secondary">
            <label>Régénération</label>
            <span class="value">{{system.regeneration}}</span>
          </div>

          <div class="resource-initiative">
            <label>Initiative</label>
            <div class="init-controls">
              <input type="number" name="system.initiative.bonus" value="{{system.initiative.bonus}}" data-dtype="Number" placeholder="0" title="Bonus"/>
              <button class="initiative-roll" type="button" title="Jet d'Initiative">
                <i class="fas fa-dice-d20"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  {{!-- Navigation Tabs --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="caracteristiques">Caractéristiques</a>
    <a class="item" data-tab="competences">Compétences</a>
    <a class="item" data-tab="combat">Combat</a>
    <a class="item" data-tab="talents">Talents</a>
    <a class="item" data-tab="magie">Magie</a>
    <a class="item" data-tab="echo">Echo</a>
    <a class="item" data-tab="effets">Effets</a>
    <a class="item" data-tab="equipement">Équipement</a>
    <a class="item" data-tab="description">Description</a>
  </nav>

  {{!-- Feuille Body --}}
  <section class="sheet-body">

    {{!-- Onglet Caractéristiques --}}
    <div class="tab caracteristiques" data-group="primary" data-tab="caracteristiques">
      
      <div class="caracteristiques-grid">
        {{#each caracteristiquesArray as |carac|}}
        <div class="caracteristique">
          <div class="carac-header">
            <h3>{{carac.label}}</h3>
          </div>
          <div class="carac-value">
            <input type="text" name="system.caracteristiques.{{carac.key}}.value" value="{{carac.value}}" data-dtype="Number"/>
          </div>
          <div class="carac-bonus">
            <label>Bonus:</label>
            <input type="text" name="system.caracteristiques.{{carac.key}}.bonus" value="{{carac.bonus}}" data-dtype="Number" placeholder="0"/>
          </div>
          <div class="carac-total">
            <strong>Total: {{add carac.value carac.bonus}}</strong>
          </div>
          <button class="caracteristique-roll" data-caracteristique="{{carac.key}}" type="button">
            <i class="fas fa-dice-d20"></i> Jet
          </button>
        </div>
        {{/each}}
      </div>

      <hr/>

      {{!-- Avantages et Désavantages --}}
      <div class="avantages-section">
        <div class="section-half">
          <div class="items-header flexrow">
            <div class="item-name">Avantages</div>
            <div class="item-controls">
              <a class="item-control item-create" data-type="avantage" title="Ajouter un avantage">
                <i class="fas fa-plus"></i> Ajouter
              </a>
            </div>
          </div>

          <ol class="items-list">
            {{#each avantages as |item id|}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>

        <div class="section-half">
          <div class="items-header flexrow">
            <div class="item-name">Désavantages</div>
            <div class="item-controls">
              <a class="item-control item-create" data-type="desavantage" title="Ajouter un désavantage">
                <i class="fas fa-plus"></i> Ajouter
              </a>
            </div>
          </div>

          <ol class="items-list">
            {{#each desavantages as |item id|}}
            <li class="item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
                <h4>{{item.name}}</h4>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
      </div>
    </div>

    {{!-- Onglet Compétences --}}
    <div class="tab competences" data-group="primary" data-tab="competences">
      <div class="items-header flexrow">
        <div class="item-name">Compétence</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="competence" title="Créer une compétence">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <div class="competences-columns">
        <div class="competences-col">
          {{!-- Colonne gauche --}}
          {{#each competencesParChamp as |groupe champ|}}
            {{#if (or (eq champ "martiale") (eq champ "mystique") (eq champ "echo") (eq champ "physique"))}}
              <h3>Compétences {{#if (eq champ "martiale")}}Martiales{{/if}}
                  {{#if (eq champ "mystique")}}Mystiques{{/if}}
                  {{#if (eq champ "echo")}}Echos{{/if}}
                  {{#if (eq champ "physique")}}Physiques{{/if}}</h3>
              
              <ol class="items-list">
                {{#each groupe as |item id|}}
                <li class="item flexrow" data-item-id="{{item._id}}">
                  <div class="item-name">
                    <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
                    <h4>{{item.name}} {{#if item.system.specialisation}}({{item.system.specialisation}}){{/if}}</h4>
                  </div>
                  <div class="item-caracteristique">
                    {{#if (eq item.system.caracteristique "vigueur")}}VIG{{/if}}
                    {{#if (eq item.system.caracteristique "coordination")}}COO{{/if}}
                    {{#if (eq item.system.caracteristique "logique")}}LOG{{/if}}
                    {{#if (eq item.system.caracteristique "instinct")}}INS{{/if}}
                    {{#if (eq item.system.caracteristique "empathie")}}EMP{{/if}}
                    {{#if (eq item.system.caracteristique "pouvoir")}}POU{{/if}}
                  </div>
                  <div class="item-niveau">
                    <input type="text" value="{{item.system.niveau}}" data-dtype="Number" placeholder="0" disabled/>
                  </div>
                  <div class="item-controls">
                    <a class="item-control item-roll" title="Lancer"><i class="fas fa-dice-d20"></i></a>
                    <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
                  </div>
                </li>
                {{/each}}
              </ol>
            {{/if}}
          {{/each}}
        </div>

        <div class="competences-col">
          {{!-- Colonne droite --}}
          {{#each competencesParChamp as |groupe champ|}}
            {{#if (or (eq champ "sociale") (eq champ "technique") (eq champ "utilitaire"))}}
              <h3>Compétences {{#if (eq champ "sociale")}}Sociales{{/if}}
                  {{#if (eq champ "technique")}}Techniques{{/if}}
                  {{#if (eq champ "utilitaire")}}Utilitaire{{/if}}</h3>
              
              <ol class="items-list">
                {{#each groupe as |item id|}}
                <li class="item flexrow" data-item-id="{{item._id}}">
                  <div class="item-name">
                    <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
                    <h4>{{item.name}} {{#if item.system.specialisation}}({{item.system.specialisation}}){{/if}}</h4>
                  </div>
                  <div class="item-caracteristique">
                    {{#if (eq item.system.caracteristique "vigueur")}}VIG{{/if}}
                    {{#if (eq item.system.caracteristique "coordination")}}COO{{/if}}
                    {{#if (eq item.system.caracteristique "logique")}}LOG{{/if}}
                    {{#if (eq item.system.caracteristique "instinct")}}INS{{/if}}
                    {{#if (eq item.system.caracteristique "empathie")}}EMP{{/if}}
                    {{#if (eq item.system.caracteristique "pouvoir")}}POU{{/if}}
                  </div>
                  <div class="item-niveau">
                    <input type="text" value="{{item.system.niveau}}" data-dtype="Number" placeholder="0" disabled/>
                  </div>
                  <div class="item-controls">
                    <a class="item-control item-roll" title="Lancer"><i class="fas fa-dice-d20"></i></a>
                    <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
                  </div>
                </li>
                {{/each}}
              </ol>
            {{/if}}
          {{/each}}
        </div>
      </div>
    </div>

    {{!-- Onglet Combat --}}
    <div class="tab combat" data-group="primary" data-tab="combat">
      <div class="items-header flexrow">
        <div class="item-name">Arme</div>
        <div class="item-degats">Dégâts</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="arme" title="Ajouter une arme">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each armes as |item id|}}
        <li class="item flexrow" data-item-id="{{item._id}}">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-degats">
            {{item.system.degats.base}}{{#if item.system.ajouteVigueur}} + VIG{{/if}}
          </div>
          <div class="item-controls">
            <a class="item-control item-roll" title="Attaquer"><i class="fas fa-dice-d20"></i></a>
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ol>

      <hr/>

      <div class="items-header flexrow">
        <div class="item-name">Armure</div>
        <div class="item-protection">Protection</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="armure" title="Ajouter une armure">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each armures as |item id|}}
        <li class="item flexrow" data-item-id="{{item._id}}">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-protection">
            E:{{item.system.protection.energie}} C:{{item.system.protection.chaleur}} F:{{item.system.protection.froid}} T:{{item.system.protection.trauma}}
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ol>

      <hr/>

      <div class="items-header flexrow">
        <div class="item-name">Bouclier</div>
        <div class="item-bonus">Bonus Parade</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="bouclier" title="Ajouter un bouclier">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each boucliers as |item id|}}
        <li class="item flexrow" data-item-id="{{item._id}}">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-bonus">
            +{{item.system.bonusParade}}
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ol>
    </div>

    {{!-- Onglet Magie --}}
    <div class="tab magie" data-group="primary" data-tab="magie">
      <div class="items-header flexrow">
        <div class="item-name">Sort</div>
        <div class="item-niveau">Rang</div>
        <div class="item-nexus">Nexus</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="sort" title="Ajouter un sort">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each sorts as |item id|}}
        <li class="item flexrow" data-item-id="{{item._id}}">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-niveau">{{item.system.rang}}</div>
          <div class="item-nexus">{{item.system.coutNexus}}</div>
          <div class="item-controls">
            <a class="item-control item-roll" title="Lancer le sort"><i class="fas fa-magic"></i></a>
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ol>
    </div>

    {{!-- Onglet Talents --}}
    <div class="tab talents" data-group="primary" data-tab="talents">
      <div class="items-header flexrow">
        <div class="item-name">Talent</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="talent" title="Ajouter un talent">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each talents as |item id|}}
        <li class="item flexrow" data-item-id="{{item._id}}">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ol>
    </div>

    {{!-- Onglet Echo --}}
    <div class="tab echo" data-group="primary" data-tab="echo">
      
      {{!-- Générateurs Echo --}}
      <div class="items-header flexrow">
        <div class="item-name">Générateur Echo</div>
        <div class="item-composition">Points de Nexus (cliquer pour utiliser/recharger)</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="generateur" title="Ajouter un générateur">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each generateurs as |item id|}}
        <li class="item flexrow generateur-dropzone" data-item-id="{{item._id}}" data-item-type="generateur">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-composition">
            <div class="nexus-controls">
              {{!-- Point 1 --}}
              {{#if item.system.nexus1.actif}}
              <span class="nexus-point-interactive {{item.system.nexus1.type}} {{#if item.system.nexus1.used}}used{{/if}}" 
                    data-item-id="{{item._id}}" 
                    data-point="nexus1"
                    title="{{#if (eq item.system.nexus1.type 'soma')}}Sôma{{/if}}{{#if (eq item.system.nexus1.type 'psykhee')}}Psykhée{{/if}}{{#if (eq item.system.nexus1.type 'nous')}}Noüs{{/if}}">
                {{#if (eq item.system.nexus1.type "soma")}}SÔMA{{/if}}{{#if (eq item.system.nexus1.type "psykhee")}}PSYKHÉE{{/if}}{{#if (eq item.system.nexus1.type "nous")}}NOÜS{{/if}}
              </span>
              {{/if}}
              {{!-- Point 2 --}}
              {{#if item.system.nexus2.actif}}
              <span class="nexus-point-interactive {{item.system.nexus2.type}} {{#if item.system.nexus2.used}}used{{/if}}" 
                    data-item-id="{{item._id}}" 
                    data-point="nexus2"
                    title="{{#if (eq item.system.nexus2.type 'soma')}}Sôma{{/if}}{{#if (eq item.system.nexus2.type 'psykhee')}}Psykhée{{/if}}{{#if (eq item.system.nexus2.type 'nous')}}Noüs{{/if}}">
                {{#if (eq item.system.nexus2.type "soma")}}SÔMA{{/if}}{{#if (eq item.system.nexus2.type "psykhee")}}PSYKHÉE{{/if}}{{#if (eq item.system.nexus2.type "nous")}}NOÜS{{/if}}
              </span>
              {{/if}}
              {{!-- Point 3 --}}
              {{#if item.system.nexus3.actif}}
              <span class="nexus-point-interactive {{item.system.nexus3.type}} {{#if item.system.nexus3.used}}used{{/if}}" 
                    data-item-id="{{item._id}}" 
                    data-point="nexus3"
                    title="{{#if (eq item.system.nexus3.type 'soma')}}Sôma{{/if}}{{#if (eq item.system.nexus3.type 'psykhee')}}Psykhée{{/if}}{{#if (eq item.system.nexus3.type 'nous')}}Noüs{{/if}}">
                {{#if (eq item.system.nexus3.type "soma")}}SÔMA{{/if}}{{#if (eq item.system.nexus3.type "psykhee")}}PSYKHÉE{{/if}}{{#if (eq item.system.nexus3.type "nous")}}NOÜS{{/if}}
              </span>
              {{/if}}
            </div>
          </div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        
        {{!-- CADs connectés à ce générateur --}}
        {{#each @root.cads as |cad|}}
          {{#if (and cad.system.brancheAuGenerateur (eq cad.system.generateurId item._id))}}
          <li class="item cad-sous-generateur" data-item-id="{{cad._id}}">
            <div class="flexrow">
              <div class="item-name" style="flex: 2;">
                <span class="tree-icon">↳</span>
                <div class="item-image"><img src="{{cad.img}}" title="{{cad.name}}" width="20" height="20"/></div>
                <h5>{{cad.name}}</h5>
              </div>
              <div class="item-composition" style="flex: 2;">
                <div class="nexus-controls">
                  {{!-- Point 1 --}}
                  {{#if cad.system.nexus1.actif}}
                  <span class="nexus-point-interactive {{cad.system.typeNexus}} {{#if cad.system.nexus1.used}}used{{/if}}" 
                        data-item-id="{{cad._id}}" 
                        data-point="nexus1"
                        title="{{#if (eq cad.system.typeNexus 'soma')}}Sôma{{/if}}{{#if (eq cad.system.typeNexus 'psykhee')}}Psykhée{{/if}}{{#if (eq cad.system.typeNexus 'nous')}}Noüs{{/if}}">
                    {{#if (eq cad.system.typeNexus "soma")}}SÔMA{{/if}}{{#if (eq cad.system.typeNexus "psykhee")}}PSYKHÉE{{/if}}{{#if (eq cad.system.typeNexus "nous")}}NOÜS{{/if}}
                  </span>
                  {{/if}}
                  {{!-- Point 2 --}}
                  {{#if cad.system.nexus2.actif}}
                  <span class="nexus-point-interactive {{cad.system.typeNexus}} {{#if cad.system.nexus2.used}}used{{/if}}" 
                        data-item-id="{{cad._id}}" 
                        data-point="nexus2"
                        title="{{#if (eq cad.system.typeNexus 'soma')}}Sôma{{/if}}{{#if (eq cad.system.typeNexus 'psykhee')}}Psykhée{{/if}}{{#if (eq cad.system.typeNexus 'nous')}}Noüs{{/if}}">
                    {{#if (eq cad.system.typeNexus "soma")}}SÔMA{{/if}}{{#if (eq cad.system.typeNexus "psykhee")}}PSYKHÉE{{/if}}{{#if (eq cad.system.typeNexus "nous")}}NOÜS{{/if}}
                  </span>
                  {{/if}}
                </div>
              </div>
              <div class="item-connection" style="flex: 2;">
                <select class="cad-generateur-select" data-cad-id="{{cad._id}}" style="width: 100%; padding: 3px;">
                  <option value="">Autonome</option>
                  {{#each @root.generateurs as |gen|}}
                    <option value="{{gen._id}}" {{#if (eq cad.system.generateurId gen._id)}}selected{{/if}}>
                      {{gen.name}}
                    </option>
                  {{/each}}
                </select>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" data-item-id="{{cad._id}}" title="Éditer"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" data-item-id="{{cad._id}}" title="Supprimer"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            
            {{!-- Sorts du CAD --}}
            {{#if cad.sortsResolus.length}}
            <div class="indent-sorts">
              {{#each cad.sortsResolus as |sort|}}
              <div class="sort-sous-cad">
                <span class="tree-icon-sort">└─</span>
                <span class="sort-name-small">{{sort.name}}</span>
                <a class="sort-roll-small" data-sort-id="{{sort._id}}" data-cad-id="{{cad._id}}" title="Lancer">
                  <i class="fas fa-dice-d20"></i>
                </a>
              </div>
              {{/each}}
            </div>
            {{/if}}
          </li>
          {{/if}}
        {{/each}}
        {{/each}}
      </ol>

      <hr/>

      {{!-- CADs (Casting Advanced Device) --}}
      <div class="items-header flexrow">
        <div class="item-name">CAD Autonomes</div>
        <div class="item-composition">Points de Nexus</div>
        <div class="item-connection">Générateur</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="cad" title="Ajouter un CAD">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each cads as |cad id|}}
          {{!-- Afficher seulement les CADs non connectés --}}
          {{#unless cad.system.brancheAuGenerateur}}
          <li class="item cad-item" data-item-id="{{cad._id}}">
            <div class="flexrow">
              <div class="item-name">
                <div class="item-image"><img src="{{cad.img}}" title="{{cad.name}}" width="24" height="24"/></div>
                <h4>{{cad.name}}</h4>
              </div>
              <div class="item-composition">
                <div class="nexus-controls">
                  {{!-- Point 1 --}}
                  {{#if cad.system.nexus1.actif}}
                  <span class="nexus-point-interactive {{cad.system.typeNexus}} {{#if cad.system.nexus1.used}}used{{/if}}" 
                        data-item-id="{{cad._id}}" 
                        data-point="nexus1"
                        title="{{#if (eq cad.system.typeNexus 'soma')}}Sôma{{/if}}{{#if (eq cad.system.typeNexus 'psykhee')}}Psykhée{{/if}}{{#if (eq cad.system.typeNexus 'nous')}}Noüs{{/if}}">
                    {{#if (eq cad.system.typeNexus "soma")}}SÔMA{{/if}}{{#if (eq cad.system.typeNexus "psykhee")}}PSYKHÉE{{/if}}{{#if (eq cad.system.typeNexus "nous")}}NOÜS{{/if}}
                  </span>
                  {{/if}}
                  {{!-- Point 2 --}}
                  {{#if cad.system.nexus2.actif}}
                  <span class="nexus-point-interactive {{cad.system.typeNexus}} {{#if cad.system.nexus2.used}}used{{/if}}" 
                        data-item-id="{{cad._id}}" 
                        data-point="nexus2"
                        title="{{#if (eq cad.system.typeNexus 'soma')}}Sôma{{/if}}{{#if (eq cad.system.typeNexus 'psykhee')}}Psykhée{{/if}}{{#if (eq cad.system.typeNexus 'nous')}}Noüs{{/if}}">
                    {{#if (eq cad.system.typeNexus "soma")}}SÔMA{{/if}}{{#if (eq cad.system.typeNexus "psykhee")}}PSYKHÉE{{/if}}{{#if (eq cad.system.typeNexus "nous")}}NOÜS{{/if}}
                  </span>
                  {{/if}}
                </div>
              </div>
              <div class="item-connection">
                <select class="cad-generateur-select" data-cad-id="{{cad._id}}" style="width: 100%; padding: 3px;">
                  <option value="">Autonome</option>
                  {{#each @root.generateurs as |gen|}}
                    <option value="{{gen._id}}">{{gen.name}}</option>
                  {{/each}}
                </select>
              </div>
              <div class="item-controls">
                <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
                <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
              </div>
            </div>
          </li>
          
          {{!-- Sorts du CAD autonome --}}
          {{#if cad.sortsResolus.length}}
          <li class="sort-list-item">
            <div class="indent-1">
              {{#each cad.sortsResolus as |sort|}}
              <div class="sort-sous-cad">
                <span class="tree-icon-sort">↳</span>
                <span class="sort-name-small">{{sort.name}}</span>
                <a class="sort-roll-small" data-sort-id="{{sort._id}}" data-cad-id="{{cad._id}}" title="Lancer">
                  <i class="fas fa-dice-d20"></i>
                </a>
              </div>
              {{/each}}
            </div>
          </li>
          {{/if}}
          {{/unless}}
        {{/each}}
      </ol>
    </div>

    {{!-- Onglet Effets actifs --}}
    <div class="tab effets" data-group="primary" data-tab="effets">
      <h2>Effets actifs</h2>
      
      {{#if actor.effects.size}}
      <ol class="items-list">
        {{#each actor.effects as |effet id|}}
        <li class="item effect-item flexrow" data-effect-id="{{effet.id}}">
          <div class="item-image">
            <img src="{{effet.icon}}" title="{{effet.name}}" width="36" height="36"/>
          </div>
          <div class="item-name">
            <h4>{{effet.name}}</h4>
            {{#if effet.duration.rounds}}
            <span class="effect-duration">⏱️ {{effet.duration.rounds}} rounds restants</span>
            {{else}}
            <span class="effect-duration">∞ Permanent</span>
            {{/if}}
          </div>
          <div class="item-details" style="flex: 3;">
            {{#if effet.changes.length}}
            <div class="effect-changes">
              {{#each effet.changes as |change|}}
              <div class="effect-change">
                <span class="change-key">{{change.key}}</span>: 
                <span class="change-value">
                  {{#if (eq change.mode 1)}}×{{/if}}
                  {{#if (eq change.mode 2)}}+{{/if}}
                  {{#if (eq change.mode 3)}}↓{{/if}}
                  {{#if (eq change.mode 4)}}↑{{/if}}
                  {{#if (eq change.mode 5)}}={{/if}}
                  {{change.value}}
                </span>
              </div>
              {{/each}}
            </div>
            {{/if}}
            {{#if effet.origin}}
            <div class="effect-source">
              <small>Source: {{effet.sourceName}}</small>
            </div>
            {{/if}}
          </div>
          <div class="item-controls">
            <a class="effect-toggle" title="{{#if effet.disabled}}Activer{{else}}Désactiver{{/if}}">
              <i class="fas {{#if effet.disabled}}fa-toggle-off{{else}}fa-toggle-on{{/if}}"></i>
            </a>
            <a class="effect-delete" title="Supprimer">
              <i class="fas fa-trash"></i>
            </a>
          </div>
        </li>
        {{/each}}
      </ol>
      {{else}}
      <p class="notes">Aucun effet actif actuellement.</p>
      <p class="notes">Les effets proviennent des talents, avantages, sorts actifs, et équipements portés.</p>
      {{/if}}
      
      <hr/>
      
      <h3>Résumé des modificateurs</h3>
      <div class="effect-summary">
        <p class="notes">Les modificateurs sont appliqués automatiquement aux valeurs de la fiche.</p>
        {{#if actor.effects.size}}
        <div class="modifier-grid">
          <div><strong>Caractéristiques :</strong> Calculées avec effets</div>
          <div><strong>Compétences :</strong> Bonus/malus appliqués</div>
          <div><strong>Combat :</strong> Dégâts et défense modifiés</div>
          <div><strong>Régénération :</strong> Bonus/malus cumulés</div>
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Onglet Équipement --}}
    <div class="tab equipement" data-group="primary" data-tab="equipement">
      <div class="items-header flexrow">
        <div class="item-name">Équipement</div>
        <div class="item-quantity">Qté</div>
        <div class="item-weight">Poids</div>
        <div class="item-controls">
          <a class="item-control item-create" data-type="equipement" title="Ajouter un équipement">
            <i class="fas fa-plus"></i> Ajouter
          </a>
        </div>
      </div>

      <ol class="items-list">
        {{#each equipements as |item id|}}
        <li class="item flexrow" data-item-id="{{item._id}}">
          <div class="item-name">
            <div class="item-image"><img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-quantity">{{item.system.quantite}}</div>
          <div class="item-weight">{{item.system.poids}} kg</div>
          <div class="item-controls">
            <a class="item-control item-edit" title="Éditer"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="Supprimer"><i class="fas fa-trash"></i></a>
          </div>
        </li>
        {{/each}}
      </ol>
    </div>

    {{!-- Onglet Description --}}
    <div class="tab description" data-group="primary" data-tab="description">
      <div class="form-group">
        <label>Taille</label>
        <input type="text" name="system.details.taille" value="{{system.details.taille}}"/>
      </div>

      <div class="form-group">
        <label>Poids</label>
        <input type="text" name="system.details.poids" value="{{system.details.poids}}"/>
      </div>

      <div class="form-group">
        <label>Apparence</label>
        <textarea name="system.details.apparence" rows="3">{{system.details.apparence}}</textarea>
      </div>

      <div class="form-group">
        <label>Histoire</label>
        <textarea name="system.details.histoire" rows="8">{{system.details.histoire}}</textarea>
      </div>
    </div>

  </section>
</form>
